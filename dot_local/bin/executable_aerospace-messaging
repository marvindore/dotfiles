#!/usr/bin/env python3
# Switches to workspace M, cycling windows if already focused there.
# If Slack or Teams are not running when switching to M, launches them so
# they auto-move via aerospace on-window-detected rules.
#
# Uses AeroSpace's Unix socket rather than the `aerospace` CLI binary —
# the .app bundle only ships the GUI launcher, no CLI binary is symlinked.
# Socket protocol: {"stdin": "", "args": [...]} → {"exitCode": ..., "stdout": ..., "stderr": ...}
import json, os, socket, subprocess, time

SOCK = f"/tmp/bobko.aerospace-{os.environ['USER']}.sock"

# Bundle IDs matching aerospace on-window-detected rules for workspace M
MESSAGING_APPS = [
    "com.tinyspeck.slackmacgap",  # Slack
    "com.microsoft.teams2",        # Microsoft Teams (new)
    "com.microsoft.teams",         # Microsoft Teams (classic)
]

def aero(*args):
    s = socket.socket(socket.AF_UNIX)
    s.settimeout(2)
    s.connect(SOCK)
    s.send(json.dumps({"stdin": "", "args": list(args)}).encode())
    time.sleep(0.1)
    r = json.loads(s.recv(4096))
    return r.get("exitCode", 1), r.get("stdout", "").strip()

def is_app_running(bundle_id):
    script = f'tell application "System Events" to exists (processes whose bundle identifier is "{bundle_id}")'
    result = subprocess.run(["osascript", "-e", script], capture_output=True, text=True)
    return result.stdout.strip() == "true"

_, ws = aero("list-workspaces", "--focused")
if ws == "M":
    aero("focus", "dfs-next", "--boundaries-action", "wrap-around-the-workspace")
else:
    for bundle_id in MESSAGING_APPS:
        if not is_app_running(bundle_id):
            subprocess.Popen(["open", "-b", bundle_id], stderr=subprocess.DEVNULL)
    aero("workspace", "M")
