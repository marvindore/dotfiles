-- Neovim + CodeCompanion setup via vim.pack.add
-- Usage:
--   - Set CHEZMOI_WORK=1 at work to use LiteLLM (HTTP)
--   - Unset CHEZMOI_WORK at home to use Gemini CLI (ACP)
-- Secrets are resolved from macOS Keychain at runtime:
--   - api_base        -> LiteLLM base URL
--   - api_key         -> LiteLLM API key
--   - gemini_api_key  -> Gemini API key

vim.pack.add({
  -- 1) Eager deps
  "https://github.com/nvim-lua/plenary.nvim",
  "https://github.com/nvim-treesitter/nvim-treesitter",
  "https://github.com/j-hui/fidget.nvim",

  -- 2) Markdown renderer (for nicer chat output)
  {
    src = "https://github.com/MeanderingProgrammer/render-markdown.nvim",
    data = {
      ft = { "markdown", "codecompanion" },
      after = function(_)
        require("render-markdown").setup({})
      end,
    },
  },

  -- 3) CodeCompanion
  {
    src = "https://github.com/olimorris/codecompanion.nvim",
    data = {
      cmd = { "CodeCompanion", "CodeCompanionChat", "CodeCompanionActions", "CodeCompanionCmd" },
      keys = {
        { lhs = "<leader>aa", rhs = "<cmd>CodeCompanionChat Toggle<CR>", mode = "n", desc = "CodeCompanion Toggle" },
        { lhs = "<leader>ax", rhs = "<cmd>CodeCompanionActions<cr>",    mode = "n", desc = "CodeCompanion Actions" },
        { lhs = "<leader>ac", rhs = "<cmd>CodeCompanionCmd<cr>",        mode = "n", desc = "CodeCompanion Command" },
      },
      after = function(_)
        -- Decide default adapter at runtime
        -- Work (CHEZMOI_WORK set): LiteLLM
        -- Home (CHEZMOI_WORK unset/empty/"0"): Gemini CLI
        local default_adapter = (function()
          local v = vim.env.CHEZMOI_WORK
          return (v ~= nil and v ~= "" and v ~= "0") and "litellm" or "gemini_home"
        end)()

        local opts = {
          -- Logging belongs under opts
          opts = {
            log_level = "DEBUG",
          },

          display = {
            action_palette = {
              width = 95,
              height = 10,
              prompt = "Prompt ",
              provider = "snacks",
              opts = {
                show_default_actions = true,
                show_default_prompt_library = true,
                title = "CodeCompanion actions",
              },
            },
          },

          adapters = {
            -- ACP adapters live here
            acp = {
              opts = { show_presets = false },

              -- Home: Gemini CLI via ACP (extend built-in adapter)
              gemini_home = function()
                return require("codecompanion.adapters").extend("gemini_cli", {
                  name = "Gemini CLI (Home)",
                  defaults = {
                    auth_method = "gemini-api-key",
                    timeout = 20000,
                    -- If you use MCP servers elsewhere in your config, you can inherit them:
                    -- mcpServers = "inherit_from_config",
                  },
                  env = {
                    -- Resolve at runtime from macOS Keychain (do not write secrets into config)
                    GEMINI_API_KEY = "cmd:security find-generic-password -s 'gemini_api_key' -w | tr -d '\n'",
                  },
                })
              end,
            },

            -- HTTP adapters live here
            http = {
              -- Work: LiteLLM via OpenAI-compatible adapter
              litellm = function()
                return require("codecompanion.adapters").extend("openai_compatible", {
                  name = "LiteLLM (Work)",
                  env = {
                    -- Resolve at runtime from macOS Keychain
                    url      = "cmd:security find-generic-password -s 'litellm_api_url' -w | tr -d '\n'",
                    api_key  = "cmd:security find-generic-password -s 'litellm_api_key'   -w | tr -d '\n'",

                    -- Many OpenAI-compatible proxies use /v1 paths; adjust if your base already includes it
                    chat_url = "/v1/chat/completions",
                  },
                  schema = {
                    -- Set your default model (as configured/available on your LiteLLM proxy)
                    model       = { default = "vertex_ai/claude-sonnet-4-6@default" },
                    num_ctx     = { default = 32000 },
                    temperature = { default = 0.2 },
                  },
                })
              end,
            },
          },

          -- Strategies choose which adapter to use
          strategies = {
            chat   = {
              adapter = default_adapter,
              slash_commands = {
                ["buffer"] = { opts = { provider = "snacks" } },
                ["file"]   = { opts = { provider = "snacks" } },
              },
            },
            inline = { adapter = default_adapter },
            cmd    = { adapter = default_adapter },
          },
        }

        -- Initialize CodeCompanion
        require("codecompanion").setup(opts)

        ----------------------------------------------------------------------
        -- Fidget progress (nice request progress UI)
        ----------------------------------------------------------------------
        local progress = require("fidget.progress")
        local handles = {}
        local group = vim.api.nvim_create_augroup("CodeCompanionFidget", {})

        vim.api.nvim_create_autocmd("User", {
          pattern = "CodeCompanionRequestStarted",
          group = group,
          callback = function(e)
            handles[e.data.id] = progress.handle.create({
              title = "CodeCompanion",
              message = "Thinking... ",
              lsp_client = { name = e.data.adapter.formatted_name },
            })
          end,
        })

        vim.api.nvim_create_autocmd("User", {
          pattern = "CodeCompanionRequestFinished",
          group = group,
          callback = function(e)
            local h = handles[e.data.id]
            if h then
              h.message = e.data.status == "success" and "Done" or "Failed"
              h:finish()
              handles[e.data.id] = nil
            end
          end,
        })
      end,
    },
  },
}, {
  -- pass to 'lze' for lazy-loading
  load = function(p)
    local spec = p.spec.data or {}
    spec.name = p.spec.name
    require("lze").load(spec)
  end,
})
