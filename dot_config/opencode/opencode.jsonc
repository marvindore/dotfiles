{
    "$schema": "https://opencode.ai/config.json",
    "provider": {
        "litellm": {
            "npm": "@ai-sdk/openai-compatible",
            "name": "LiteLLM Proxy",
            "options": {
                "baseURL": "http://192.168.1.50:4000/v1",
                "apiKey": "none"
            },
            "models": {
                "gemini": {
                    "name": "Gemini Flash"
                }
            }
        }
    },
    "model": "litellm/gemini",
    "permission": {
        "read": "allow",
        "edit": "allow",
        "bash": "ask",
        "webfetch": "allow"
    },
    "tools": {
        "bash": true,
        "mcp": true
    },
    "keybinds": {
        "input_newline": "ctrl+n"
    },
    "agent": {
        "architect": {
            "description": "Planning and high-level design",
            "model": "litellm/gemini-3.1-pro-preview",
            "tools": {
                "edit": false,
                "bash": false
            },
            "prompt": "You are a software architect. Focus on system design, directories, and scalability. Do not write implementation code."
        }
    }
}
