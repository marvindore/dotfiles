{{- /* Load data from .chezmoidata.yaml */ -}}
{{- $workOrg  := .work_org_slug -}}
{{- $isDarwin := eq .chezmoi.os "darwin" -}}
{{- $homeKey  := .ssh.personalKey | default "~/.ssh/marvin" -}}
{{- $workKey  := .ssh.workKey     | default "~/.ssh/work" -}}
{{- $colimaOn := .ssh.enable_colima_include | default true -}}

# =========================
# Includes (keep near top)
# =========================
{{- if and $isDarwin $colimaOn }}
Include {{ .chezmoi.homeDir }}/.colima/ssh_config
{{- end }}

# =========================
# GitHub — HOME / personal
# Usage: git@home:ORG/REPO.git
# =========================
Host home
  HostName github.com
  User git
  IdentityFile {{ $homeKey }}
  IdentitiesOnly yes

# =========================
# GitHub — WORK ({{ $workOrg }})
# Usage: git@work:{{ $workOrg }}/REPO.git
# =========================
Host work
  HostName github.com
  User git
  IdentityFile {{ $workKey }}
  IdentitiesOnly yes
