# Unload Kanata and revert to native keyboard instantly
alias k-stop="sudo launchctl bootout system /Library/LaunchDaemons/com.example.kanata.plist"

# Reload Kanata (useful after editing config.kbd)
alias k-start="sudo launchctl bootstrap system /Library/LaunchDaemons/com.example.kanata.plist"

# The brute-force panic button (kills the process, but LaunchDaemon might restart it)
alias k-kill="sudo killall kanata"

# --- Check status ---
function kanata_status() {
    echo "--- Status ---"
    
    if pgrep -x "kanata" >/dev/null; then
        echo "🟢 Kanata: RUNNING (PID: $(pgrep -x kanata))"
    else
        echo "🔴 Kanata: STOPPED"
    fi

    # Check process AND Kernel status
    if pgrep -f "Karabiner-VirtualHIDDevice-Daemon" >/dev/null; then
        if ioreg -l | grep -q "Karabiner-DriverKit-VirtualHIDDevice"; then
             echo "🟢 Driver: RUNNING & LINKED (Ready)"
        else
             echo "YA Driver: RUNNING (But not linked to Kernel yet)"
        fi
    else
        echo "🔴 Driver: STOPPED"
    fi
}

function darwin_upgrade() {
  local dest_dir="$HOME/.config/nix-darwin"
  # Dynamically ask chezmoi for the source path
  local src_dir=$(chezmoi source-path "$dest_dir")

  # Safety check
  if [ ! -d "$src_dir" ]; then
    echo "Error: Cannot find chezmoi source directory at $src_dir."
    echo "Please ensure you have run 'chezmoi add ~/.config/nix-darwin'"
    return 1
  fi

  echo "Updating flake.lock in chezmoi source ($src_dir)..."
  cd "$src_dir" || return 1
  
  # Update happens in the source repo
  nix flake update
  
  # Push the freshly updated flake.lock to the system path
  echo "Applying updated lock file to system path..."
  chezmoi apply "$dest_dir"
  
  cd - > /dev/null
}

function darwin_update() {
  local dest_dir="$HOME/.config/nix-darwin"
  # Dynamically ask chezmoi for the source path
  local src_dir=$(chezmoi source-path "$dest_dir")

  # Safety check
  if [ ! -d "$src_dir" ]; then
    echo "Error: Cannot find chezmoi source directory at $src_dir."
    echo "Please ensure you have run 'chezmoi add ~/.config/nix-darwin'"
    return 1
  fi

  # 1. Move to the source directory to build.
  cd "$src_dir" || return 1
  echo "Building system configuration as unprivileged user..."
  nix build .#darwinConfigurations.mchip.system

  if [ $? -eq 0 ]; then
    # 2. If build succeeds, push the exact config/lock to the system
    echo "Syncing config and lock file to system..."
    chezmoi apply "$dest_dir"

    # 3. Switch the system using the newly synced destination files
    echo "Build successful. Switching system configuration as root..."
    sudo darwin-rebuild switch --flake "$dest_dir#mchip"
  else
    echo "Nix build failed. Aborting switch."
  fi

  # 4. Manage the garbage collection roots (now located in your source dir)
  rm -rf ./result
  cd - > /dev/null
}

function cht() {
# :list
# :learn
# sub topic
    if [ -z "$1" ]; then
        lang=$(curl -s cht.sh/:list | fzf)
    else
        lang="$1"
    fi

    [ -z "$lang" ] && return

    topic=$(
      {
        echo "ALL"
        curl -s "cht.sh/$lang/:list"
      } | fzf
    )

    [ -z "$topic" ] && return

    if [[ "$topic" == "ALL" ]]; then
      curl -s "cht.sh/$lang" | bat
    else
      curl -s "cht.sh/$lang/$topic" | bat
    fi
}

# markdown browser preview
mdp() {
  if [[ $# -eq 0 ]]; then
    pnpm dlx mdts --port 8521
  elif [[ -f "$1" ]]; then
    pnpm dlx mdts . -g "$1" "${@:2}" --port 8521
  else
    pnpm dlx mdts "$@" --port 8521
  fi
}

